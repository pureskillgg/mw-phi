{
  "name": "@pureskillgg/phi",
  "version": "6.0.3",
  "description": "Functional tools for JavaScript inspired by Ramda and Ramda Adjunct.",
  "type": "module",
  "main": "index.js",
  "exports": {
    "import": "./index.js"
  },
  "module": "index.js",
  "sideEffects": false,
  "keywords": [
    "meltwater",
    "ramda",
    "ramda adjunct",
    "node"
  ],
  "homepage": "https://github.com/pureskillgg/mw-phi",
  "bugs": "https://github.com/pureskillgg/mw-phi/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pureskillgg/mw-phi.git"
  },
  "license": "MIT",
  "author": {
    "name": "Evan Sosenko",
    "email": "evan.sosenko@meltwater.com"
  },
  "files": [
    "package-lock.json",
    "index.js",
    "lib"
  ],
  "scripts": {
    "test": "c8 ava",
    "pretest": "node index.js",
    "test:update": "ava --update-snapshots",
    "test:watch": "ava --watch",
    "test:debug": "ava debug --break",
    "lint": "npm-run-all --parallel lint:*",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check --ignore-path .gitignore '**/*.{js,cjs,mjs,json,yml,yaml,graphql}'",
    "build:docs": "jsdoc -c jsdoc.json",
    "prepublishOnly": "npm-run-all --parallel lint test",
    "preversion": "npm-run-all --parallel lint test",
    "postversion": "git push --follow-tags",
    "example": "node examples",
    "example:inspect": "node --inspect examples",
    "format": "npm-run-all --parallel format:*",
    "preformat": "prettier --write --ignore-path .gitignore '**/*.{js,cjs,mjs,json,yml,yaml,graphql}'",
    "format:js": "eslint --fix .",
    "report": "c8 report"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "ramda": "^0.32.0",
    "ramda-adjunct": "^6.1.0"
  },
  "devDependencies": {
    "@pureskillgg/examplr": "^8.0.1",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "docdash": "^2.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdoc": "^4.0.5",
    "neostandard": "^0.13.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4"
  }
}
